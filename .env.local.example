# ============================================================
# .env.local — 이 파일을 복사해서 .env.local 로 저장 후 값을 채우세요
# ============================================================

# Supabase (프로젝트 Settings > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Jira Cloud (NEXT_PUBLIC 없음 — 서버 사이드 전용)
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=ATATT3xFfGF0...  # https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_TARGET_LABEL=planning-request  # 수집할 지라 라벨 (쉼표 구분 가능)
